# ─── Application ───────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-64-char-string
DEBUG=false

# ─── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://tamiltts:password@localhost:5432/tamiltts

# ─── Redis / Celery ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── Google Cloud TTS ──────────────────────────────────────────
# Path to your service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=/etc/tamiltts/gcp-key.json

# ─── Storage ───────────────────────────────────────────────────
OUTPUT_DIR=/var/lib/tamiltts/outputs

# ─── Limits ────────────────────────────────────────────────────
MAX_UPLOAD_BYTES=5242880        # 5 MB
JWT_EXPIRE_MINUTES=1440         # 24 hours
RATE_LIMIT_JOBS_PER_HOUR=10

# ─── Chunking ──────────────────────────────────────────────────
CHUNK_TARGET_MIN=1200
CHUNK_TARGET_MAX=1800
SILENCE_MS=350

# ─── Debug ─────────────────────────────────────────────────────
KEEP_CHUNK_FILES=false
